# Copy to .env and fill in. See docs/support/environment.md.

# Path to the WindNinja CLI binary (or your docker invocation wrapper)
WINDNINJA_CLI=/usr/local/bin/WindNinja_cli

# WindNinja data dir (contains ninjafoam.zip templates for the momentum solver), if needed
WINDNINJA_DATA=/usr/local/share/windninja/data

# Where Sillage caches prepared DEMs, forecasts, and OpenFOAM cases
SILLAGE_CACHE_DIR=./cache

# Only needed if using Meteo-France AROME (Open-Meteo needs no key for typical use)
METEOFRANCE_API_KEY=
